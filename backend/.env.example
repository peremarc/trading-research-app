# Core runtime
DATABASE_URL=sqlite:///./trading_research.db
DATABASE_AUTO_UPGRADE_ON_STARTUP=true
BOOTSTRAP_SEED_ON_STARTUP=true

# Scheduler
SCHEDULER_RUN_ON_STARTUP=false
SCHEDULER_MODE=continuous
SCHEDULER_CONTINUOUS_IDLE_SECONDS=5
SCHEDULER_MARKET_CLOSED_IDLE_SECONDS=1800

# Market data
MARKET_DATA_PROVIDER=ibkr_proxy
IBKR_PROXY_BASE_URL=http://127.0.0.1:15177
IBKR_PROXY_API_KEY=

# External backtesting service
BACKTESTING_ENABLED=true
BACKTESTING_PROVIDER=remote_service
BACKTESTING_BASE_URL=http://127.0.0.1:15181
BACKTESTING_API_KEY=
BACKTESTING_TIMEOUT_SECONDS=30
BACKTESTING_SOURCE_APP=trading-research-app
BACKTESTING_RECONCILE_ENABLED=true
BACKTESTING_RECONCILE_INTERVAL_SECONDS=30
BACKTESTING_RECONCILE_BATCH_SIZE=10

# Optional AI integrations
AI_AGENT_ENABLED=true
AI_PRIMARY_PROVIDER=codex_gateway
AI_PRIMARY_MODEL=gpt-5.3-codex-spark
GEMINI_API_KEY=
GEMINI_API_KEY_FREE1=
GEMINI_API_KEY_FREE2=
CODEX_GATEWAY_BASE_URL=http://127.0.0.1:15175
CODEX_GATEWAY_MODEL_LABEL=gpt-5.3-codex-spark
CODEX_GATEWAY_API_KEY=
CHAT_LLM_DEFAULT=codex-gateway
AI_REQUEST_TIMEOUT_SECONDS=120
AI_FALLBACK_API_BASE=
AI_FALLBACK_API_KEY=
